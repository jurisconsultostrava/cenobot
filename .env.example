# KURZ (StoneX vrací ceny v EUR, převádíme na CZK)
FX_CZK_EUR=24.183
# nebo živý kurz z endpointu vracejícího {"czk_eur": 24.18}:
FX_API_URL=

# MARŽE nad StoneX cenou (%). Pozor: buď zde, NEBO cenový koeficient v Shoptetu.
MARZE_PCT=1.25

# BEZPEČNOST
MAX_ZMENA_PCT=15

# REGENERACE FEEDU
INTERVAL_MIN=15
MARKET_OPEN_HOUR=8
MARKET_CLOSE_HOUR=22

# SERVER
PORT=8080
FEED_OUTPUT=ceny_feed.xml
FEED_TOKEN=
